# Copy to .env and fill in to go live against the real Grok Voice Agent API.
# Without a key the app runs in MOCK mode (full pipeline, simulated model).
XAI_API_KEY=
# Close CRM sync (https://app.close.com/settings/api/) — leave empty to disable
CLOSE_API_KEY=
# Telephony: signing secret printed by scripts/register-number.js (shown once)
XAI_WEBHOOK_SECRET=
# GROK_URL=wss://api.x.ai/v1/realtime?model=grok-voice-latest
# PORT=3100
